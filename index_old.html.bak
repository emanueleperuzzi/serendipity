  <!-- Cambio immagine gallery -->
  <script>
    const featuredImage = document.getElementById("featuredImage");
    const thumbs = Array.from(document.querySelectorAll(".thumb"));
    const prevButton = document.querySelector(".gallery-arrow-prev");
    const nextButton = document.querySelector(".gallery-arrow-next");
    const galleryFeatured = document.querySelector(".gallery-featured");

    let currentIndex = 0;

    function showImage(index) {
      const thumb = thumbs[index];

      if (!thumb) {
        return;
      }

      featuredImage.src = thumb.dataset.full;
      featuredImage.alt = thumb.dataset.alt;

      thumbs.forEach((item) => item.classList.remove("is-active"));
      thumb.classList.add("is-active");

      thumb.scrollIntoView({
        block: "nearest",
        inline: "nearest"
      });

      currentIndex = index;
    }

    thumbs.forEach((thumb, index) => {
      thumb.addEventListener("click", () => {
        showImage(index);
      });
    });

    prevButton.addEventListener("click", () => {
      const previousIndex = (currentIndex - 1 + thumbs.length) % thumbs.length;
      showImage(previousIndex);
    });

    nextButton.addEventListener("click", () => {
      const nextIndex = (currentIndex + 1) % thumbs.length;
      showImage(nextIndex);
    });

    galleryFeatured.addEventListener("click", () => {
      galleryFeatured.focus();
    });

    galleryFeatured.addEventListener("keydown", (event) => {
      if (event.key === "ArrowLeft") {
        event.preventDefault();
        const previousIndex = (currentIndex - 1 + thumbs.length) % thumbs.length;
        showImage(previousIndex);
      }

      if (event.key === "ArrowRight") {
        event.preventDefault();
        const nextIndex = (currentIndex + 1) % thumbs.length;
        showImage(nextIndex);
      }
    });
  </script>

</body>

